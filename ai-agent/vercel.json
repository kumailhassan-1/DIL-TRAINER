{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/widget.js",
      "dest": "/public/widget.js"
    },
    {
      "src": "/widget.css",
      "dest": "/public/widget.css"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/demo.html"
    }
  ]
}
