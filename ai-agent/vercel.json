{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/widget.js",
      "dest": "/public/widget.js"
    },
    {
      "src": "/widget.css",
      "dest": "/public/widget.css"
    },
    {
      "src": "/demo.html",
      "dest": "/public/demo.html"
    }
  ]
}
